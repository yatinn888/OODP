#include <iostream>
using namespace std;

// Base class
class Student {
protected:
    int roll;
    string name;

public:
    void getStudent() {
        cout << "Enter Roll Number: ";
        cin >> roll;

        cout << "Enter Name: ";
        cin >> name;
    }

    void displayStudent() {
        cout << "\nStudent Details" << endl;
        cout << "Roll Number: " << roll << endl;
        cout << "Name: " << name << endl;
    }
};

// Derived class
class Result : public Student {
private:
    int m1, m2, m3;
    int total;
    float average;

public:
    void getMarks() {
        getStudent();

        cout << "Enter marks of 3 subjects: ";
        cin >> m1 >> m2 >> m3;

        total = m1 + m2 + m3;
        average = total / 3.0;
    }

    void displayResult() {
        displayStudent();

        cout << "\nMarks:" << endl;
        cout << "Subject1: " << m1 << endl;
        cout << "Subject2: " << m2 << endl;
        cout << "Subject3: " << m3 << endl;

        cout << "Total: " << total << endl;
        cout << "Average: " << average << endl;
    }
};

int main() {
    Result r;

    r.getMarks();
    r.displayResult();

    return 0;
}
